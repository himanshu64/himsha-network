# Copy to .env and adjust. NEVER commit .env.
# These are dev-only regtest credentials — change them for anything real.

BITCOIN_NETWORK=regtest

# Bitcoin Core RPC credentials (used by both bitcoind and himsha-node).
BITCOIN_RPC_USER=himuser
BITCOIN_RPC_PASS=devpass_change_me

# Host ports.
BITCOIN_RPC_PORT=18443
HIMSHA_NODE_PORT=9100
ORD_PORT=8080

# Enable the dev faucet (himsha_requestAirdrop / himsha_createAccountWithFaucet).
HIMSHA_FAUCET=1

# How often the node polls Bitcoin Core for new blocks (seconds).
BITCOIN_SYNC_INTERVAL_SECS=5

# Log filter.
RUST_LOG=himsha_node=info,warn
